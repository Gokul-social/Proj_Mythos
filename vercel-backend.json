{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/ws",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "SOLANA_NETWORK": "@solana_network",
    "HELIUS_API_KEY": "@helius_api_key",
    "MYTHOS_PROGRAM_ID": "@mythos_program_id",
    "GROQ_API_KEY": "@groq_api_key"
  }
}
